    {
      "id": "ab62887f-988c-41ca-bdbc-76f1e2107ce8",
      "board_id": "ffe8e9bd-40d7-45ea-82a1-d0fbe6b750a7",
      "title": "第二步：zshrc配置",
      "content": "export NVM_DIR=\"$HOME/.nvm\"\r\n[ -s \"$NVM_DIR/nvm.sh\" ] && \\. \"$NVM_DIR/nvm.sh\"\r\n[ -s \"$NVM_DIR/bash_completion\" ] && \\. \"$NVM_DIR/bash_completion\"\r\nexport http_proxy=\"http://gy245:strategy@10.24.10.245:3128\"\r\nexport HTTP_PROXY=\"http://gy245:strategy@10.24.10.245:3128\"\r\nexport https_proxy=\"http://gy245:strategy@10.24.10.245:3128\"\r\nexport HTTPS_PROXY=\"http://gy245:strategy@10.24.10.245:3128\"",
      "description": "",
      "tags": [
        "cc"
      ],
      "is_favorite": false,
      "created_at": "2026-03-19T17:35:29.082295",
