      "board_id": "ffe8e9bd-40d7-45ea-82a1-d0fbe6b750a7",
      "title": "第七步：配置api",
      "content": "{\n  \"env\": {\n    \"ANTHROPIC_AUTH_TOKEN\": \"your_api_token\",\n    \"ANTHROPIC_BASE_URL\": \"https://open.bigmodel.cn/api/anthropic\",\n    \"ANTHROPIC_DEFAULT_HAIKU_MODEL\": \"glm-4.7\",\n    \"ANTHROPIC_DEFAULT_SONNET_MODEL\": \"glm-5\",\n    \"ANTHROPIC_DEFAULT_OPUS_MODEL\": \"glm-5\",\n    \"API_TIMEOUT_MS\": \"3000000\",\n    \"CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC\": \"1\",\n    \"HTTP_PROXY\": \"http://gy245:strategy@10.24.10.245:3128\",\n    \"HTTPS_PROXY\": \"http://gy245:strategy@10.24.10.245:3128\"\n  },\n  \"enabledPlugins\": {\n    \"document-skills@anthropic-agent-skills\": true,\n    \"superpowers@claude-plugins-official\": true\n  },\n  \"language\": \"中文\"\n}",
      "description": "写入~/.claude/settings.json",
      "tags": [
        "cc"
      ],
